{
  "name": "Big Data – Hadoop (Pseudo-distributed)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "remoteUser": "hadoop",
  "containerUser": "hadoop",
  "forwardPorts": [9870, 9864, 8088, 8042, 19888, 9000],
  "portsAttributes": {
    "9870": {
      "label": "HDFS NameNode UI",
      "onAutoForward": "notify"
    },
    "9864": {
      "label": "HDFS DataNode UI",
      "onAutoForward": "notify"
    },
    "8088": {
      "label": "YARN ResourceManager UI",
      "onAutoForward": "notify"
    },
    "8042": {
      "label": "YARN NodeManager UI",
      "onAutoForward": "silent"
    },
    "19888": {
      "label": "MapReduce History Server",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "bash /usr/local/bin/init-hadoop.sh",
  "postStartCommand": "bash /usr/local/bin/start-hadoop.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.java",
        "vscjava.vscode-java-pack",
        "ms-python.python"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.inheritEnv": false,
        "terminal.integrated.env.linux": {
          "JAVA_HOME": "/usr/lib/jvm/java-11-openjdk-amd64",
          "HADOOP_HOME": "/opt/hadoop",
          "HADOOP_CONF_DIR": "/opt/hadoop/etc/hadoop",
          "PYSPARK_PYTHON": "/usr/bin/python3",
          "PYSPARK_DRIVER_PYTHON": "/usr/bin/python3",
          "PATH": "/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:/opt/hadoop/bin:/opt/hadoop/sbin:/usr/lib/jvm/java-11-openjdk-amd64/bin"
        }
      }
    }
  }
}
