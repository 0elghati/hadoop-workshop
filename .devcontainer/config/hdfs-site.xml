<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
  hdfs-site.xml – HDFS-specific settings
  Single-node pseudo-distributed mode: replication factor = 1
-->
<configuration>

  <!-- Replication factor: 1 for a single-node cluster -->
  <property>
    <name>dfs.replication</name>
    <value>1</value>
  </property>

  <!-- NameNode storage -->
  <property>
    <name>dfs.namenode.name.dir</name>
    <value>file:///hadoop/hdfs/namenode</value>
  </property>

  <!-- DataNode storage -->
  <property>
    <name>dfs.datanode.data.dir</name>
    <value>file:///hadoop/hdfs/datanode</value>
  </property>

  <!-- Enable WebHDFS REST API -->
  <property>
    <name>dfs.webhdfs.enabled</name>
    <value>true</value>
  </property>

  <!-- Bind NameNode HTTP to all interfaces so the UI is reachable -->
  <property>
    <name>dfs.namenode.http-address</name>
    <value>0.0.0.0:9870</value>
  </property>

  <!-- Bind DataNode HTTP to all interfaces -->
  <property>
    <name>dfs.datanode.http.address</name>
    <value>0.0.0.0:9864</value>
  </property>

  <!-- Disable permission checks (easier for classroom use) -->
  <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
  </property>

</configuration>
